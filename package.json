{
  "name": "ims-product-warehouse-auth",
  "version": "1.0.0",
  "description": "IMS Module: Product, Warehouse & Authentication",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"npx vite\"",
    "server": "node server/index.js",
    "test": "node --test server/tests/*.test.js && NODE_OPTIONS=--experimental-vm-modules jest --runInBand --forceExit --testTimeout=20000"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.1.0",
    "vite": "^6.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ]
  }
}
